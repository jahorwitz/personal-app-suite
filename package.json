{
  "name": "jahorwitz-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/personal-site' dev",
    "build": "pnpm -r build",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "overrides": {
      "tar": "^7.5.9",
      "qs": ">=6.14.1",
      "validator": ">=13.15.22",
      "fast-xml-parser": ">=5.3.6",
      "node-forge": ">=1.3.2",
      "jws": ">=4.0.1",
      "body-parser": ">=2.2.1",
      "minimatch": ">=10.2.1",
      "test-exclude": ">=7.0.0",
      "sucrase>glob": ">=11.1.0",
      "@storybook/cli>glob": ">=11.1.0",
      "@joshwooding/vite-plugin-react-docgen-typescript>glob": ">=11.1.0",
      "@ardatan/relay-compiler": ">=12.0.1",
      "js-yaml": "4.1.1",
      "@istanbuljs/load-nyc-config>js-yaml": "3.14.2",
      "diff": ">=8.0.3",
      "ajv": ">=8.18.0"
    }
  }
}
